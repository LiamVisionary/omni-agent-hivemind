{
  "name": "hivemindos-honey-ledger-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create hivemindos_honey_ledger",
    "d1:migrate:local": "wrangler d1 execute hivemindos_honey_ledger --local --file=./schema.sql",
