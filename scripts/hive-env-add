#!/usr/bin/env python3
"""Add or update local HivemindOS environment variables.

The command keeps plaintext secrets local, then optionally refreshes an
encrypted folder-backed note backup when GPG configuration is available.
"""
from __future__ import annotations

import argparse
import getpass
import json
import os
import pathlib
import re
import shlex
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.request
from typing import Iterable

SCRIPT_PATH = pathlib.Path(__file__).resolve()
ROOT = pathlib.Path(os.path.expanduser(os.environ.get("HIVE_ENV_PROJECT_ROOT", ""))).resolve() if os.environ.get("HIVE_ENV_PROJECT_ROOT") else SCRIPT_PATH.parents[1]
DEFAULT_ENV_FILE = ROOT / ".env.local"
DEFAULT_AGENT_ENV_FILE = pathlib.Path.home() / ".hivemindos" / ".env"
DEFAULT_NOTE_ROOT_CANDIDATES = [
    pathlib.Path.home() / "Documents" / "Obsidian" / "hivemindos-vault",
    pathlib.Path.home() / "Documents" / "Obsidian" / "HivemindOS Vault",
    pathlib.Path.home() / "Documents" / "Obsidian" / "Agent Team Vault",
]
OPENCLAW_DIR = pathlib.Path.home() / ".openclaw"
OPENCLAW_JSON = OPENCLAW_DIR / "openclaw.json"
OPENCLAW_SECRETS = OPENCLAW_DIR / "secrets.json"
HERMES_ENV_FILE = pathlib.Path.home() / ".hermes" / ".env"
AEON_ENV_FILE = pathlib.Path.home() / ".aeon" / ".env"

KEY_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")
LOCAL_ONLY_KEYS = {
    "HIVE_AGENT_ENV_FILE",
    "HIVE_ENV_BACKUP_DIR",
    "HIVE_ENV_COLLECTOR_PORT",
    "HIVE_ENV_FILE",
    "HIVE_ENV_GPG_RECIPIENT",
    "HIVE_ENV_PROJECT_ROOT",
    "HIVE_ENV_PUBLIC_KEY",
    "HIVE_ENV_TAILNET_SYNC",
    "HIVE_ENV_TAILNET_TARGETS",
    "HIVE_ENV_TAILNET_USER",
    "HIVE_ENV_TAILNET_VERBOSE",
    "HIVE_NOTE_ROOT",
    "HIVE_NOTE_SECURE_FOLDER",
    "HIVE_SHARED_BRAIN_PATH",
    "NEXT_ALLOWED_DEV_ORIGINS",
    "NEXT_PUBLIC_OBSIDIAN_VAULT_PATH",
    "NEXT_PUBLIC_TAILNET_SYNC_ENABLED",
}


def parse_env_text(data: str) -> dict[str, str]:
    parsed: dict[str, str] = {}
    for raw_line in data.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        if key.startswith("export "):
            key = key.split(" ", 1)[1]
        key = key.strip()
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] == '"':
            value = bytes(value[1:-1], "utf-8").decode("unicode_escape")
        elif len(value) >= 2 and value[0] == value[-1] == "'":
            value = value[1:-1]
        parsed[key] = value
    return parsed


def parse_env_file(path: pathlib.Path) -> dict[str, str]:
    try:
        data = path.read_text()
    except FileNotFoundError:
        return {}
    return parse_env_text(data)


def local_setting(key: str) -> str:
    for path in (ROOT / ".env.local", ROOT / ".env"):
        value = parse_env_file(path).get(key)
        if value:
            return value
    return ""


def truthy(value: str | None) -> bool:
    return (value or "").strip().lower() in {"1", "true", "yes", "on"}


def quote_env(value: str) -> str:
    if value == "" or any(ch.isspace() or ch in "#'\"\\$`" for ch in value):
        return shlex.quote(value)
    return value


def update_env_file(path: pathlib.Path, key: str, value: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    lines = path.read_text().splitlines() if path.exists() else []
    replacement = f"{key}={quote_env(value)}"
    found = False
    output: list[str] = []

    for line in lines:
        stripped = line.strip()
        if stripped.startswith("#") or "=" not in line:
            output.append(line)
            continue
        existing_key = line.split("=", 1)[0].removeprefix("export ").strip()
        if existing_key == key:
            if not found:
                output.append(replacement)
                found = True
            continue
        output.append(line)

    if not found:
        if output and output[-1].strip():
            output.append("")
        output.append(replacement)

    path.write_text("\n".join(output) + "\n")
    path.chmod(0o600)


def remove_env_file_key(path: pathlib.Path, key: str) -> None:
    if not path.exists():
        return
    lines = path.read_text().splitlines()
    output: list[str] = []
    for line in lines:
        stripped = line.strip()
        if stripped.startswith("#") or "=" not in line:
            output.append(line)
            continue
        existing_key = line.split("=", 1)[0].removeprefix("export ").strip()
        if existing_key == key:
            continue
        output.append(line)
    path.write_text("\n".join(output).rstrip() + ("\n" if output else ""))
    path.chmod(0o600)


def env_meta_file(path: pathlib.Path) -> pathlib.Path:
    return path.with_name(path.name + ".meta.json")


def read_env_meta(path: pathlib.Path) -> dict[str, float]:
    meta_path = env_meta_file(path)
    if not meta_path.exists():
        return {}
    try:
        data = json.loads(meta_path.read_text())
    except json.JSONDecodeError:
        return {}
    if not isinstance(data, dict):
        return {}
    updated_at = data.get("updatedAt")
    if not isinstance(updated_at, dict):
        return {}
    return {str(key): float(value) for key, value in updated_at.items() if isinstance(value, (int, float))}


def write_env_meta(path: pathlib.Path, updated_at: dict[str, float]) -> None:
    meta_path = env_meta_file(path)
    meta_path.parent.mkdir(parents=True, exist_ok=True)
    meta_path.write_text(json.dumps({"version": 1, "updatedAt": dict(sorted(updated_at.items()))}, indent=2) + "\n")
    meta_path.chmod(0o600)


def touch_env_meta(path: pathlib.Path, keys: Iterable[str]) -> None:
    updated_at = read_env_meta(path)
    now = time.time()
    for key in keys:
        updated_at[key] = now
    write_env_meta(path, updated_at)


def read_json(path: pathlib.Path) -> dict[str, object]:
    if not path.exists():
        return {}
    try:
        raw = re.sub(r"//[^\n]*", "", path.read_text())
        return json.loads(raw)
    except json.JSONDecodeError:
        return {}


def write_json(path: pathlib.Path, data: dict[str, object]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    path.write_text(json.dumps(data, indent=2) + "\n")
    path.chmod(0o600)


def update_openclaw_stores(key: str, value: str) -> None:
    secrets = read_json(OPENCLAW_SECRETS)
    if value == "":
        secrets.pop(key, None)
    else:
        secrets[key] = value
    write_json(OPENCLAW_SECRETS, secrets)

    config = read_json(OPENCLAW_JSON)
    env = config.get("env")
    if not isinstance(env, dict):
        env = {}
    vars_ = env.get("vars")
    if not isinstance(vars_, dict):
        vars_ = {}
    if value == "":
        vars_.pop(key, None)
    else:
        vars_[key] = value
    env["vars"] = vars_
    config["env"] = env
    write_json(OPENCLAW_JSON, config)


def openclaw_values() -> dict[str, str]:
    values: dict[str, str] = {}
    config = read_json(OPENCLAW_JSON)
    env = config.get("env")
    config_vars = env.get("vars") if isinstance(env, dict) else {}
    for source in (read_json(OPENCLAW_SECRETS), config_vars):
        if isinstance(source, dict):
            for key, value in source.items():
                if isinstance(key, str) and isinstance(value, str):
                    values[key] = value
    return values


def aeon_repo(args: argparse.Namespace) -> str:
    return (
        args.aeon_repo
        or os.environ.get("AEON_REPO")
        or local_setting("AEON_REPO")
        or os.environ.get("NEXT_PUBLIC_AEON_REPO")
        or local_setting("NEXT_PUBLIC_AEON_REPO")
    ).strip()


def sync_aeon_github_secret(args: argparse.Namespace, key: str, value: str, quiet: bool = False) -> bool:
    if not args.sync_aeon_github_secret:
        return True
    repo = aeon_repo(args)
    if not repo:
        raise RuntimeError("Aeon GitHub secret sync requested, but no --aeon-repo or AEON_REPO is configured.")
    if shutil.which("gh") is None:
        raise RuntimeError("Aeon GitHub secret sync requested, but gh is not installed.")
    proc = subprocess.run(
        ["gh", "secret", "set", key, "-R", repo],
        input=value,
        text=True,
        capture_output=True,
        check=False,
        timeout=20,
    )
    if proc.returncode != 0:
        detail = (proc.stderr or proc.stdout).strip()
        raise RuntimeError(f"failed to sync {key} to Aeon GitHub secrets for {repo}: {detail}")
    if not quiet:
        print(f"synced Aeon GitHub secret {key} to {repo}")
    return True

def agent_env_file(args: argparse.Namespace) -> pathlib.Path:
    raw = (
        args.agent_env_file
        or os.environ.get("HIVE_AGENT_ENV_FILE")
        or local_setting("HIVE_AGENT_ENV_FILE")
        or str(DEFAULT_AGENT_ENV_FILE)
    )
    return pathlib.Path(os.path.expanduser(raw)).resolve()


def note_root() -> pathlib.Path | None:
    raw = (
        os.environ.get("HIVE_NOTE_ROOT")
        or os.environ.get("HIVE_SHARED_BRAIN_PATH")
        or os.environ.get("NEXT_PUBLIC_OBSIDIAN_VAULT_PATH")
        or local_setting("HIVE_NOTE_ROOT")
        or local_setting("HIVE_SHARED_BRAIN_PATH")
        or local_setting("NEXT_PUBLIC_OBSIDIAN_VAULT_PATH")
    )
    if not raw:
        return next((candidate.resolve() for candidate in DEFAULT_NOTE_ROOT_CANDIDATES if candidate.exists()), None)
    return pathlib.Path(os.path.expanduser(raw)).resolve()


def backup_dir() -> pathlib.Path | None:
    raw = os.environ.get("HIVE_ENV_BACKUP_DIR") or local_setting("HIVE_ENV_BACKUP_DIR")
    if raw:
        return pathlib.Path(os.path.expanduser(raw)).resolve()
    root = note_root()
    if not root:
        return None
    folder = (
        os.environ.get("HIVE_NOTE_SECURE_FOLDER")
        or local_setting("HIVE_NOTE_SECURE_FOLDER")
        or "Notes/Secure"
    )
    return root / folder


def public_key_candidates(directory: pathlib.Path) -> Iterable[pathlib.Path]:
    configured = os.environ.get("HIVE_ENV_PUBLIC_KEY") or local_setting("HIVE_ENV_PUBLIC_KEY")
    if configured:
        yield pathlib.Path(os.path.expanduser(configured)).resolve()
    yield directory / "hive-env-public-key.asc"
    yield directory / "liam-hermes-env-public-key.asc"


def import_public_key(path: pathlib.Path) -> str:
    show = subprocess.run(
        ["gpg", "--with-colons", "--import-options", "show-only", "--import", str(path)],
        text=True,
        capture_output=True,
        check=False,
    )
    if show.returncode != 0:
        return ""
    fingerprint = ""
    for line in show.stdout.splitlines():
        parts = line.split(":")
        if parts and parts[0] == "fpr" and len(parts) > 9:
            fingerprint = parts[9]
            break
    if fingerprint:
        subprocess.run(["gpg", "--import", str(path)], text=True, capture_output=True, check=False)
    return fingerprint


def refresh_encrypted_backup(env_file: pathlib.Path) -> str | None:
    directory = backup_dir()
    if not directory:
        return "No note root configured; skipped encrypted env backup."
    if shutil.which("gpg") is None:
        return "gpg is not installed; skipped encrypted env backup."

    recipient = os.environ.get("HIVE_ENV_GPG_RECIPIENT") or local_setting("HIVE_ENV_GPG_RECIPIENT")
    if not recipient:
        for candidate in public_key_candidates(directory):
            if candidate.exists():
                recipient = import_public_key(candidate)
                if recipient:
                    break
    if not recipient:
        return f"No HIVE_ENV_GPG_RECIPIENT or public key found in {directory}; skipped encrypted env backup."

    directory.mkdir(parents=True, exist_ok=True)
    output = directory / "hive.env.gpg"
    with tempfile.NamedTemporaryFile("w", delete=False) as tmp:
        tmp_path = pathlib.Path(tmp.name)
        tmp.write(env_file.read_text() if env_file.exists() else "")
    try:
        proc = subprocess.run(
            ["gpg", "--batch", "--yes", "--trust-model", "always", "--encrypt", "--recipient", recipient, "--output", str(output), str(tmp_path)],
            text=True,
            capture_output=True,
            check=False,
        )
    finally:
        try:
            tmp_path.unlink()
        except FileNotFoundError:
            pass
    if proc.returncode != 0:
        return f"Encrypted backup failed: {proc.stderr.strip() or proc.stdout.strip()}"
    output.chmod(0o600)
    return f"refreshed encrypted backup: {output}"


def backup_env_file(args: argparse.Namespace, env_file: pathlib.Path) -> pathlib.Path:
    if args.scope == "agent" and args.runtime == "generic":
        return agent_env_file(args)
    return env_file


def env_store_file(args: argparse.Namespace, env_file: pathlib.Path) -> pathlib.Path:
    if args.scope in ("all", "app"):
        return env_file
    if args.runtime == "hermes":
        return HERMES_ENV_FILE
    if args.runtime == "aeon":
        return AEON_ENV_FILE
    if args.runtime == "generic":
        return agent_env_file(args)
    return OPENCLAW_SECRETS


def backup_applies(args: argparse.Namespace) -> bool:
    return args.scope in ("all", "app") or (args.scope == "agent" and args.runtime == "generic")


def encrypted_backup_path() -> pathlib.Path | None:
    directory = backup_dir()
    if not directory:
        return None
    return directory / "hive.env.gpg"


def maybe_refresh_encrypted_backup(args: argparse.Namespace, env_file: pathlib.Path) -> None:
    if args.no_backup or not backup_applies(args):
        return
    message = refresh_encrypted_backup(backup_env_file(args, env_file))
    if message:
        print(message, file=sys.stderr if "failed" in message.lower() else sys.stdout)


def export_backup_status(args: argparse.Namespace, env_file: pathlib.Path) -> None:
    path = encrypted_backup_path()
    target = backup_env_file(args, env_file)
    payload = {
        "version": 1,
        "scope": args.scope,
        "runtime": args.runtime,
        "envFile": str(target),
        "backupPath": str(path) if path else "",
        "backupExists": bool(path and path.exists()),
        "gpgAvailable": shutil.which("gpg") is not None,
        "backupApplies": backup_applies(args),
    }
    print(json.dumps(payload, sort_keys=True))


def restore_encrypted_backup(args: argparse.Namespace, env_file: pathlib.Path) -> int:
    if not backup_applies(args):
        print("Encrypted backup restore only applies to app env or the generic shared agent env.", file=sys.stderr)
        return 2
    path = encrypted_backup_path()
    if not path:
        print("No note root configured; cannot find encrypted env backup.", file=sys.stderr)
        return 1
    if not path.exists():
        print(f"Encrypted env backup not found: {path}", file=sys.stderr)
        return 1
    if shutil.which("gpg") is None:
        print("gpg is not installed; cannot restore encrypted env backup.", file=sys.stderr)
        return 1

    target = backup_env_file(args, env_file)
    target.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", delete=False) as tmp:
        tmp_path = pathlib.Path(tmp.name)
    try:
        proc = subprocess.run(
            ["gpg", "--decrypt", str(path)],
            text=True,
            capture_output=True,
            check=False,
            timeout=60,
        )
        if proc.returncode != 0:
            detail = (proc.stderr or proc.stdout).strip()
            print(detail or "Could not decrypt encrypted env backup.", file=sys.stderr)
            return 1
        tmp_path.write_text(proc.stdout)
        tmp_path.chmod(0o600)
        shutil.copyfile(tmp_path, target)
        target.chmod(0o600)
    finally:
        try:
            tmp_path.unlink()
        except FileNotFoundError:
            pass

    values = shared_env_values(args, env_file)
    print(f"restored {len(values)} env key{'s' if len(values) != 1 else ''} from encrypted backup")
    if not args.no_tailnet_sync:
        sync_tailnet_updates(args, values)
    return 0


def tailscale_local_ips(data: dict[str, object]) -> set[str]:
    self_data = data.get("Self")
    if not isinstance(self_data, dict):
        return set()
    return {str(value) for value in self_data.get("TailscaleIPs") or []}


def tailscale_peer_targets() -> list[dict[str, str]]:
    configured = os.environ.get("HIVE_ENV_TAILNET_TARGETS") or local_setting("HIVE_ENV_TAILNET_TARGETS")
    if configured:
        return [
            {"host": target.strip(), "ip": target.strip(), "user": ""}
            for target in sorted({target.strip() for target in configured.split(",") if target.strip()})
        ]
    if shutil.which("tailscale") is None:
        return []
    proc = subprocess.run(["tailscale", "status", "--json"], text=True, capture_output=True, check=False)
    if proc.returncode != 0:
        return []
    try:
        data = json.loads(proc.stdout)
    except json.JSONDecodeError:
        return []

    local_ips = tailscale_local_ips(data)
    targets: list[dict[str, str]] = []
    for peer in (data.get("Peer") or {}).values():
        if not isinstance(peer, dict) or peer.get("Online") is False:
            continue
        ip = next((str(value) for value in peer.get("TailscaleIPs") or [] if re.match(r"^\d+\.\d+\.\d+\.\d+$", str(value))), "")
        if not ip or ip in local_ips:
            continue
        target_host = str(peer.get("DNSName") or "").rstrip(".") or ip
        user = env_sync_user_from_collector(ip)
        if user:
            targets.append({"host": target_host, "ip": ip, "user": user})
    return sorted(targets, key=lambda target: target["host"])


def env_sync_user_from_collector(ip: str) -> str:
    port = os.environ.get("HIVE_ENV_COLLECTOR_PORT") or local_setting("HIVE_ENV_COLLECTOR_PORT") or "8787"
    try:
        with urllib.request.urlopen(f"http://{ip}:{port}/health", timeout=2) as response:
            data = json.loads(response.read().decode("utf-8"))
    except Exception:
        return ""
    env_sync = data.get("envSync")
    if not isinstance(env_sync, dict) or env_sync.get("ready") is not True:
        return ""
    user = str(env_sync.get("user") or "").strip()
    return user if KEY_RE.match(user.replace("-", "_")) or re.match(r"^[A-Za-z0-9._-]+$", user) else ""


def target_candidates(target: str) -> list[str]:
    if "@" in target:
        return [target]
    configured_user = os.environ.get("HIVE_ENV_TAILNET_USER") or local_setting("HIVE_ENV_TAILNET_USER")
    if configured_user:
        return [f"{configured_user}@{target}"]
    return [target]


def tailnet_sync_enabled(args: argparse.Namespace) -> bool:
    return not args.no_tailnet_sync


def remote_hive_command(args: argparse.Namespace, key: str) -> str:
    remote_args = remote_update_args(args, key)
    return remote_hive_shell_command(remote_args)


def remote_hive_shell_command(remote_args: list[str]) -> str:
    quoted = " ".join(shlex.quote(part) for part in remote_args)
    return (
        "if command -v hive-env-add >/dev/null 2>&1; then "
        f"exec hive-env-add {quoted}; "
        "elif [ -x \"$HOME/.local/bin/hive-env-add\" ]; then "
        f"exec \"$HOME/.local/bin/hive-env-add\" {quoted}; "
        "else echo 'hive-env-add is not installed on this machine' >&2; exit 127; fi"
    )


def remote_update_args(args: argparse.Namespace, key: str) -> list[str]:
    remote_args = [
        "--stdin",
        "--scope", args.scope,
        "--runtime", args.runtime,
        "--no-backup",
        "--no-tailnet-sync",
    ]
    if args.env_file:
        remote_args.extend(["--env-file", args.env_file])
    if args.agent_env_file:
        remote_args.extend(["--agent-env-file", args.agent_env_file])
    remote_args.append(key)
    return remote_args


def sync_target_over_collector(target: dict[str, str], args: argparse.Namespace, updates: dict[str, str]) -> tuple[bool, str]:
    port = os.environ.get("HIVE_ENV_COLLECTOR_PORT") or local_setting("HIVE_ENV_COLLECTOR_PORT") or "8787"
    url = f"http://{target['ip']}:{port}/env"
    payload = json.dumps({
        "scope": args.scope,
        "runtime": args.runtime,
        "entries": updates,
    }).encode("utf-8")
    request = urllib.request.Request(url, data=payload, headers={"content-type": "application/json"}, method="POST")
    try:
        with urllib.request.urlopen(request, timeout=20) as response:
            data = json.loads(response.read().decode("utf-8") or "{}")
    except Exception as error:
        return False, str(error)
    if data.get("ok") is True:
        return True, ""
    return False, str(data.get("error") or "collector env sync failed")


def shared_env_values(args: argparse.Namespace, env_file: pathlib.Path) -> dict[str, str]:
    values: dict[str, str] = {}
    if args.scope in ("all", "app"):
        values.update(parse_env_file(env_file))
    if args.scope in ("all", "agent"):
        if args.runtime == "openclaw":
            values.update(openclaw_values())
        elif args.runtime == "hermes":
            values.update(parse_env_file(HERMES_ENV_FILE))
        elif args.runtime == "aeon":
            values.update(parse_env_file(AEON_ENV_FILE))
        else:
            values.update(parse_env_file(agent_env_file(args)))
    return {
        key: value
        for key, value in values.items()
        if KEY_RE.match(key) and key not in LOCAL_ONLY_KEYS
    }


def sync_tailnet_updates(args: argparse.Namespace, updates: dict[str, str]) -> None:
    if not updates or not tailnet_sync_enabled(args):
        return
    targets = tailscale_peer_targets()
    if not targets:
        print("tailnet env sync enabled, but no online Tailscale peers were found")
        return

    synced = 0
    failed: list[str] = []
    attempted_targets = 0
    for target in targets:
        attempted_targets += 1
        ok, detail = sync_target_over_collector(target, args, updates)
        if ok:
            synced += 1
        else:
            failed.append(f"{target['host']}: {detail}")

    if synced:
        print(f"tailnet env sync updated {synced} peer{'s' if synced != 1 else ''}")
    if failed:
        if truthy(os.environ.get("HIVE_ENV_TAILNET_VERBOSE") or local_setting("HIVE_ENV_TAILNET_VERBOSE")):
            print(
                "tailnet env sync skipped "
                + ", ".join(failed)
                + " (run setup on that machine and ensure the telemetry collector is reachable)",
                file=sys.stderr,
            )
        else:
            print(
                f"tailnet env sync: {len(failed)} of {attempted_targets} peer{'s' if attempted_targets != 1 else ''} not ready; set HIVE_ENV_TAILNET_VERBOSE=true for details",
                file=sys.stderr,
            )


def export_json(args: argparse.Namespace, env_file: pathlib.Path) -> None:
    values = shared_env_values(args, env_file)
    updated_at = read_env_meta(env_store_file(args, env_file))
    payload = {
        "version": 1,
        "scope": args.scope,
        "runtime": args.runtime,
        "values": values,
        "updatedAt": {key: updated_at.get(key, 0) for key in values},
    }
    print(json.dumps(payload, sort_keys=True))


def pull_from_peer(args: argparse.Namespace, env_file: pathlib.Path, target: str) -> int:
    command = remote_hive_shell_command([
        "--export-json",
        "--scope", args.scope,
        "--runtime", args.runtime,
    ])
    proc = subprocess.run(
        ["tailscale", "ssh", target, command],
        text=True,
        capture_output=True,
        check=False,
        timeout=30,
    )
    if proc.returncode != 0:
        print((proc.stderr or proc.stdout).strip() or f"could not pull env from {target}", file=sys.stderr)
        return 1
    try:
        payload = json.loads(proc.stdout)
    except json.JSONDecodeError:
        print(f"{target} did not return valid hive-env-add export JSON", file=sys.stderr)
        return 1
    raw_values = payload.get("values")
    if not isinstance(raw_values, dict):
        print(f"{target} returned no env values", file=sys.stderr)
        return 1
    incoming = {key: value for key, value in raw_values.items() if isinstance(key, str) and isinstance(value, str) and KEY_RE.match(key)}
    current = shared_env_values(args, env_file)
    applied = 0
    applied_values: dict[str, str] = {}
    skipped = 0
    conflicts: list[str] = []
    for key, value in incoming.items():
        if key in current and current[key] != value:
            if args.conflict == "fail":
                conflicts.append(key)
                continue
            if args.conflict == "local-wins":
                skipped += 1
                continue
        apply_update(args, env_file, key, value, quiet=True)
        applied += 1
        applied_values[key] = value
    if conflicts:
        print("conflicting keys: " + ", ".join(sorted(conflicts)), file=sys.stderr)
        return 1
    print(f"pulled {applied} env key{'s' if applied != 1 else ''} from {target}" + (f"; skipped {skipped} local conflict{'s' if skipped != 1 else ''}" if skipped else ""))
    if applied:
        maybe_refresh_encrypted_backup(args, env_file)
    if applied and not args.no_tailnet_sync:
        sync_tailnet_updates(args, applied_values)
    return 0


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Add or update a HivemindOS env var in local app/runtime stores.",
    )
    parser.add_argument("assignment", nargs="?", help="KEY=value, or KEY to prompt for the value")
    parser.add_argument("--env-file", default="")
    parser.add_argument("--agent-env-file", default="")
    parser.add_argument("--scope", choices=("all", "app", "agent"), default="all")
    parser.add_argument(
        "--runtime",
        choices=("generic", "hermes", "aeon", "openclaw"),
        default=os.environ.get("HIVE_AGENT_RUNTIME", "generic"),
        help="Runtime target for --scope agent. Defaults to a generic hive agent env file.",
    )
    parser.add_argument(
        "--import-env",
        action="store_true",
        help="Import every valid key from the existing Hermes env source into the selected hive scope.",
    )
    parser.add_argument(
        "--import-stdin",
        action="store_true",
        help="Import .env assignments from stdin into the selected hive scope.",
    )
    parser.add_argument(
        "--reconcile",
        action="store_true",
        help="Push the current shared env set from this machine to every ready Tailnet peer.",
    )
    parser.add_argument(
        "--pull-from",
        default="",
        metavar="USER@HOST",
        help="Pull shared env keys from a trusted Tailnet peer and merge them into this machine.",
    )
    parser.add_argument(
        "--conflict",
        choices=("local-wins", "remote-wins", "fail"),
        default="local-wins",
        help="Conflict policy for --pull-from. Defaults to preserving local values.",
    )
    parser.add_argument(
        "--export-json",
        action="store_true",
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--backup-status",
        action="store_true",
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--restore-backup",
        action="store_true",
        help="Restore this env store from the encrypted shared-note backup, then sync it to ready Tailnet peers.",
    )
    parser.add_argument(
        "--stdin",
        action="store_true",
        help=argparse.SUPPRESS,
    )
    parser.add_argument("--no-backup", action="store_true", help="Skip encrypted shared-note backup refresh")
    parser.add_argument("--no-tailnet-sync", action="store_true", help="Do not replicate this update to ready Tailnet collectors")
    parser.add_argument("--aeon-repo", default="", help="owner/repo target for --sync-aeon-github-secret")
    parser.add_argument(
        "--sync-aeon-github-secret",
        action="store_true",
        help="When --runtime aeon is selected, also set the key as a GitHub Actions secret on the Aeon repo.",
    )
    return parser.parse_args()


def apply_update(args: argparse.Namespace, env_file: pathlib.Path, key: str, value: str, quiet: bool = False) -> None:
    touched_file = env_store_file(args, env_file)
    if args.scope in ("all", "app"):
        if value == "":
            remove_env_file_key(env_file, key)
        else:
            update_env_file(env_file, key, value)
        if not quiet:
            print(f"updated {env_file}: {key}")
    if args.scope in ("all", "agent"):
        if args.runtime == "openclaw":
            update_openclaw_stores(key, value)
            if not quiet:
                print(f"updated OpenClaw runtime secret stores: {key}")
        elif args.runtime == "hermes":
            if value == "":
                remove_env_file_key(HERMES_ENV_FILE, key)
            else:
                update_env_file(HERMES_ENV_FILE, key, value)
            if not quiet:
                print(f"updated Hermes runtime env: {key}")
        elif args.runtime == "aeon":
            if value == "":
                remove_env_file_key(AEON_ENV_FILE, key)
            else:
                update_env_file(AEON_ENV_FILE, key, value)
            if not quiet:
                print(f"updated Aeon runtime env: {key}")
            sync_aeon_github_secret(args, key, value, quiet=quiet)
        else:
            path = agent_env_file(args)
            if value == "":
                remove_env_file_key(path, key)
            else:
                update_env_file(path, key, value)
            if not quiet:
                print(f"updated generic hive agent env {path}: {key}")
    touch_env_meta(touched_file, [key])


def main() -> int:
    args = parse_args()
    env_file = pathlib.Path(os.path.expanduser(
        args.env_file
        or os.environ.get("HIVE_ENV_FILE")
        or local_setting("HIVE_ENV_FILE")
        or str(DEFAULT_ENV_FILE)
    )).resolve()

    if args.export_json:
        export_json(args, env_file)
        return 0

    if args.backup_status:
        export_backup_status(args, env_file)
        return 0

    if args.restore_backup:
        return restore_encrypted_backup(args, env_file)

    if args.pull_from:
        return pull_from_peer(args, env_file, args.pull_from)

    if args.reconcile:
        values = shared_env_values(args, env_file)
        if not values:
            print("No local shared env keys found to reconcile.", file=sys.stderr)
            return 1
        sync_tailnet_updates(args, values)
        maybe_refresh_encrypted_backup(args, env_file)
        return 0

    if args.import_env:
        source = pathlib.Path(os.path.expanduser(os.environ.get("HERMES_ENV_FILE", str(HERMES_ENV_FILE)))).resolve()
        values = parse_env_file(source)
        valid_values = {key: value for key, value in values.items() if KEY_RE.match(key)}
        if not source.exists():
            print(f"Hermes env source not found: {source}", file=sys.stderr)
            return 1
        if not valid_values:
            print(f"No valid env keys found in {source}", file=sys.stderr)
            return 1
        for key, value in valid_values.items():
            apply_update(args, env_file, key, value, quiet=True)
        print(f"imported {len(valid_values)} keys from {source}")
        maybe_refresh_encrypted_backup(args, env_file)
        sync_tailnet_updates(args, valid_values)
        return 0

    if args.import_stdin:
        values = parse_env_text(sys.stdin.read())
        valid_values = {key: value for key, value in values.items() if KEY_RE.match(key)}
        if not valid_values:
            print("No valid env keys found on stdin", file=sys.stderr)
            return 1
        for key, value in valid_values.items():
            apply_update(args, env_file, key, value, quiet=True)
        print(f"imported {len(valid_values)} keys from stdin")
        maybe_refresh_encrypted_backup(args, env_file)
        sync_tailnet_updates(args, valid_values)
        return 0

    if not args.assignment:
        print("Usage: hive-env-add KEY=value, hive-env-add KEY, hive-env-add --import-env, hive-env-add --import-stdin, hive-env-add --reconcile, or hive-env-add --pull-from USER@HOST", file=sys.stderr)
        return 2

    if "=" in args.assignment:
        key, value = args.assignment.split("=", 1)
    elif args.stdin:
        key = args.assignment
        value = sys.stdin.read()
    else:
        key = args.assignment
        value = getpass.getpass(f"{key}=")

    if not KEY_RE.match(key):
        print(f"Invalid env key: {key!r}", file=sys.stderr)
        return 2

    apply_update(args, env_file, key, value)

    maybe_refresh_encrypted_backup(args, env_file)
    sync_tailnet_updates(args, {key: value})
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
