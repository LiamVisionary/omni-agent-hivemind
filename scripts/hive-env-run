#!/usr/bin/env python3
"""Run a command with the canonical shared HivemindOS env loaded.

This helper intentionally prints no secret values. It reads ~/.hivemindos/.env,
overlays the current process environment, and execs the requested command so the
child process can use credentials without the agent/model reading them.
"""
from __future__ import annotations

import os
import pathlib
import shlex
import sys

DEFAULT_ENV_FILE = pathlib.Path.home() / ".hivemindos" / ".env"


def parse_env_file(path: pathlib.Path) -> dict[str, str]:
    try:
        data = path.read_text()
    except FileNotFoundError:
        return {}

    parsed: dict[str, str] = {}
    for raw_line in data.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        if line.startswith("export "):
            line = line[len("export ") :].strip()
        key, value = line.split("=", 1)
        key = key.strip()
        if not key:
            continue
        try:
            parts = shlex.split(value, posix=True)
            value = parts[0] if parts else ""
        except ValueError:
            value = value.strip().strip('"').strip("'")
        parsed[key] = value
    return parsed


def env_files() -> list[pathlib.Path]:
    override = os.environ.get("HIVE_ENV_FILES", "").strip()
    if not override:
        return [DEFAULT_ENV_FILE]
    return [pathlib.Path(os.path.expanduser(part)).resolve() for part in override.split(os.pathsep) if part]


def usage() -> int:
    print("Usage: hive-env-run [--env-file PATH] [--] command [args...]", file=sys.stderr)
    return 2


def main(argv: list[str]) -> int:
    files = env_files()
    args = list(argv)
    while args:
        if args[0] == "--":
            args.pop(0)
            break
        if args[0] == "--env-file":
            if len(args) < 2:
                return usage()
            files = [pathlib.Path(os.path.expanduser(args[1])).resolve()]
            del args[:2]
            continue
        if args[0].startswith("--env-file="):
            files = [pathlib.Path(os.path.expanduser(args[0].split("=", 1)[1])).resolve()]
            args.pop(0)
            continue
        if args[0] in ("-h", "--help"):
            return usage()
        break

    if not args:
        return usage()

    child_env: dict[str, str] = {}
    for env_file in files:
        child_env.update(parse_env_file(env_file))
    child_env.update({key: value for key, value in os.environ.items() if value})

    os.execvpe(args[0], args, child_env)
    return 127


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
