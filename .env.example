OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=

NEXT_PUBLIC_HERMES_BASE_URL=http://127.0.0.1:8642
NEXT_PUBLIC_AEON_BASE_URL=http://127.0.0.1:8799
MIROSHARK_BASE_URL=http://127.0.0.1:5001
# Optional explicit install path. Otherwise OpenClaw detects common local locations.
MIROSHARK_HOME=
# Optional admin token for MiroShark mutation endpoints such as publish/export.
# The Swarm tab can generate and store this in MiroShark's local .env automatically.
MIROSHARK_ADMIN_TOKEN=
# Optional public fallback for local browser-visible config
NEXT_PUBLIC_MIROSHARK_BASE_URL=http://127.0.0.1:5001
# Optional: leave this default or blank to auto-detect a local Obsidian vault.
NEXT_PUBLIC_OBSIDIAN_VAULT_PATH=~/Documents/Obsidian/OpenClaw Vault
NEXT_PUBLIC_OBSIDIAN_KANBAN_FOLDER=Projects/OpenClaw/Kanban
OBSIDIAN_CLI_PATH=obsidian
NEXT_PUBLIC_HERMES_CONTROL_ROOM_PATH=~/agent-control-room

# Optional fallback AI route
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# Optional web search tool for /api/chat/agent
TAVILY_API_KEY=
EXA_API_KEY=
