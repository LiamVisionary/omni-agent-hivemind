OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=

NEXT_PUBLIC_HERMES_BASE_URL=http://127.0.0.1:8642
NEXT_PUBLIC_AEON_A2A_URL=http://127.0.0.1:41241
NEXT_PUBLIC_AEON_REPO=
NEXT_PUBLIC_AEON_LOCAL_PATH=
MIROSHARK_BASE_URL=http://127.0.0.1:5001
# Optional explicit install path. Otherwise the MiroShark adapter detects common local locations.
MIROSHARK_HOME=
# Optional admin token for MiroShark mutation endpoints such as publish/export.
# The Swarm tab can generate and store this in MiroShark's local .env automatically.
MIROSHARK_ADMIN_TOKEN=
# Optional public fallback for local browser-visible config
NEXT_PUBLIC_MIROSHARK_BASE_URL=http://127.0.0.1:5001
# Optional: leave this default or blank to auto-detect a local Obsidian vault.
NEXT_PUBLIC_OBSIDIAN_VAULT_PATH=~/Documents/Obsidian/hivemindos-vault
NEXT_PUBLIC_OBSIDIAN_KANBAN_FOLDER=Projects/HivemindOS/Kanban
# setup.sh writes true when Tailscale is installed and logged in.
NEXT_PUBLIC_TAILNET_SYNC_ENABLED=false
# Optional comma-separated hostnames/IPs allowed to load Next dev assets.
# Usually auto-detected from `tailscale ip -4` and MagicDNS when Tailscale is installed.
NEXT_ALLOWED_DEV_ORIGINS=
OBSIDIAN_CLI_PATH=obsidian
NEXT_PUBLIC_HERMES_CONTROL_ROOM_PATH=~/agent-control-room
# Optional folder-backed notes provider root for encrypted hive-env-add backups.
# Defaults to NEXT_PUBLIC_OBSIDIAN_VAULT_PATH when blank.
HIVE_NOTE_ROOT=
HIVE_NOTE_SECURE_FOLDER=Notes/Secure
HIVE_ENV_BACKUP_DIR=
HIVE_ENV_GPG_RECIPIENT=
HIVE_ENV_PUBLIC_KEY=
# Optional generic agent env target for hive-env-add. Runtime compatibility
# modes remain explicit via HIVE_AGENT_RUNTIME=hermes|aeon|openclaw.
HIVE_AGENT_ENV_FILE=~/.hivemindos/.env
HIVE_AGENT_RUNTIME=generic
# setup.sh writes true when Tailscale is installed and Tailscale SSH is enabled.
HIVE_ENV_TAILNET_SYNC=false
# setup.sh writes the local user so peer sync can try user@host before root fallback.
HIVE_ENV_TAILNET_USER=
HIVE_ENV_COLLECTOR_PORT=8787
# Optional comma-separated override such as root@ubuntu.tailnet.ts.net,liam@mac.tailnet.ts.net.
HIVE_ENV_TAILNET_TARGETS=
HIVE_ENV_TAILNET_VERBOSE=false

# Optional fallback AI route
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# Optional web search tool for /api/chat/agent
TAVILY_API_KEY=
EXA_API_KEY=

# Public official Honey ledger endpoint. Safe to commit. The backend stores the
# official balance; frontend values are display-only.
HONEY_LEDGER_REMOTE_URL=https://hivemindos-honey-ledger.hivemindos.workers.dev
HONEY_LEDGER_ISSUER_ID=hivemindos
HONEY_COMPUTE_GATEWAY_URL=https://hivemindos-compute-gateway.hivemindos.workers.dev

# Private official signer value. Normal clones leave this blank; official Honey
# is minted by the trusted compute gateway, not by client-reported token usage.
HONEY_LEDGER_SIGNING_SECRET=
